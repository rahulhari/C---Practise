{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "C/C++: clang++ build active file",
      "type": "shell",
      "command": "/usr/bin/clang++",
      "args": [
        "-std=gnu++14",
        "-fcolor-diagnostics",
        "-fansi-escape-codes",
        "-g",
        "${file}",
        "-o",
        "${fileDirname}/${fileBasenameNoExtension}"
      ],
      "options": {
        "cwd": "${fileDirname}"
      },
      "problemMatcher": ["$gcc"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "detail": "Generated clang++ build task to link C++ standard library"
    }
  ]
}
